# ── 后端讯飞 API（server.js 用，server 进程持 key，浏览器 bundle 不再包含）──
# 在讯飞 MaaS 控制台拿到的 API key + secret 拼接（冒号分隔）
IFLYTEK_API_KEY=<api-key>:<api-secret>
IFLYTEK_MODEL=astron-code-latest

# ── iron-session 密钥 ──
# 必须 ≥32 字符。建议命令生成：
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SALARY_SESSION_PASSWORD=<generate-with-the-command-above>
# 本地 dev 留 false；HTTPS 部署改 true 或删掉这行（默认严格）
SALARY_COOKIE_SECURE=false

# ── API 服务端口（与 vite.config.js 的 proxy target 对应）──
# vite dev 跑 :3000，server.js 跑 :4001，vite 把 /api/* 转发到 server.js
PORT=4001

# ── 部署到 /a500/ 子路径时打开 ──
# VITE_BASE_PATH=/a500/
# SALARY_COOKIE_PATH=/a500
